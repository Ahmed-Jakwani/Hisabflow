<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="module_category_odoo_saas_kit" model="ir.module.category">
        <field name="name">Odoo SaaS Kit</field>
        <field name="description">Handles all the operations regarding Odoo SaaS.</field>
        <field name="sequence">0</field>
    </record>

    <record id="privilege_odoo_saas_kit" model="res.groups.privilege">
        <field name="name">Odoo SaaS Kit</field>
        <field name="category_id" ref="module_category_odoo_saas_kit"/>
    </record>

    <record id="group_saas_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_odoo_saas_kit"/>
        <field name="comment">The user has read-only access to the SaaS configurations and records.</field>
    </record>

    <record id="group_saas_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_odoo_saas_kit"/>
        <field name="comment">The user has full access to all SaaS configurations and records.</field>
        <field name="implied_ids" eval="[(4, ref('group_saas_user'))]"/>
        <field name="user_ids" eval="[
            (4, ref('base.user_root')),
            (4, ref('base.user_admin'))
        ]"/>
    </record>

</odoo>